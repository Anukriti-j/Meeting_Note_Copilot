# Copy this file to .env and fill in your key. Never commit the real .env.
# Get a key at https://aistudio.google.com/apikey -- Google AI Studio's Gemini API is
# OpenAI-API-compatible, so we call it using the `openai` SDK with a custom base_url.
GOOGLE_API_KEY=AIza...

# Model + generation settings (Session 1: chosen on purpose, not left at defaults)
GOOGLE_MODEL=gemini-flash-lite-latest
SUMMARY_TEMPERATURE=0.2
AGENT_TEMPERATURE=0.0
RAG_TEMPERATURE=0.1

# faster-whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=base

# RAG tuning
RAG_TOP_K=10
RAG_MIN_SIMILARITY=0.35

# Agent safety
MAX_ITERATIONS=5
